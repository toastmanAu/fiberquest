{
  "name": "fiberquest",
  "version": "0.1.0",
  "description": "Retro gaming platform powered by Fiber Network micropayments",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "server": "node src/game-server.js",
    "test:rpc": "node scripts/test-rpc.js",
    "build": "electron-builder --linux",
    "build:arm64": "electron-builder --linux --arm64",
    "build:x64": "electron-builder --linux --x64"
  },
  "dependencies": {
    "@ckb-ccc/ccc": "^1.1.25",
    "@ckb-ccc/connector-react": "^1.0.34",
    "@ckb-ccc/core": "^1.12.5",
    "@ckb-ccc/spore": "^1.5.17",
    "@ckb-ccc/ssri": "^0.2.22",
    "@nervosnetwork/ckb-sdk-utils": "^0.109.5",
    "@nervosnetwork/ckb-types": "^0.109.5",
    "axios": "^1.6.0",
    "bignumber.js": "^10.0.2",
    "blake2b": "^2.1.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.wyltek.fiberquest",
    "productName": "FiberQuest",
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game"
    },
    "extraMetadata": {
      "main": "src/main.js"
    }
  }
}
